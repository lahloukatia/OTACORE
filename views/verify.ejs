<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>OTACORE - Verify Email</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="auth-body">
  <div class="signup-card">

    <div class="logo-container">
      <div class="logo-icon">
        <i class="bi bi-envelope-check-fill"></i>
      </div>
      <h1 class="brand-name">OTACORE</h1>
      <p class="tagline">Check your email for the verification code.</p>
    </div>

    <!-- Email affiché -->
    <div class="verify-email-info">
      <i class="bi bi-envelope"></i>
      Code sent to <strong><%= email %></strong>
    </div>

    <!-- Erreur -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert-error">
        <i class="bi bi-exclamation-circle"></i> <%= error %>
      </div>
    <% } %>

    <!-- Formulaire code -->
    <form action="/auth/verify" method="POST">
      <input type="hidden" name="email" value="<%= email %>"/>

      <div class="form-group">
        <label>Verification Code</label>
        <div class="code-inputs">
          <input type="text" name="code" maxlength="6"
                 placeholder="000000"
                 class="code-input" required
                 autocomplete="off"/>
        </div>
        <p class="code-hint">Enter the 6-digit code sent to your email</p>
      </div>

      <button type="submit" class="btn-signup">
        <i class="bi bi-check-lg"></i> Verify Account
      </button>
    </form>

    <!-- Renvoyer le code -->
    <div class="footer-text" style="margin-top:16px;">
      Didn't receive the code ?
      <a href="/auth/resend?email=<%= email %>">Resend</a>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>