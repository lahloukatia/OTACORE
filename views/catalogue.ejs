<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>OTACORE - <%= type === 'ANIME' ? 'Anime' : 'Manga' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="landing-body">

  <%- include('partials/navbar') %>

  <!-- ══ HERO ALÉATOIRE ══ -->
  <% if (featured) { %>
    <% 
      // featured is a Contenu with Genres array (through many-to-many)
      const genresText = featured.Genres && featured.Genres.length > 0 
        ? featured.Genres.map(g => g.libelle).join(' • ') 
        : '';
    %>
    <section class="cat-hero">
      <div class="details-hero-bg"
           style="background-image: url('<%= featured.image_url %>')">
      </div>
      <div class="details-hero-overlay"></div>
      <div class="cat-hero-content">
        <div class="details-type-badge">
          <% if (type === 'ANIME') { %>
            <i class="bi bi-play-circle"></i> Anime
          <% } else { %>
            <i class="bi bi-book"></i> Manga
          <% } %>
        </div>
        <h1 class="hero-title">
          <%= featured.titre.split(' ')[0] %>
          <span><%= featured.titre.split(' ').slice(1).join(' ') %></span>
        </h1>
        <div class="hero-meta">
          <span class="match-score"><%= featured.note %>/5 ⭐</span>
          <span class="meta-dot"></span>
          <span><%= featured.date_sortie %></span>
          <span class="meta-dot"></span>
          <span class="meta-tag"><%= featured.age_recommande %>+</span>
          <% if (genresText) { %>
            <span class="meta-dot"></span>
            <span><%= genresText %></span>
          <% } %>
        </div>
        <p class="hero-synopsis"><%= featured.synopsis ? featured.synopsis.substring(0, 150) + '...' : '' %></p>
        <div class="hero-actions">
          <a href="/contenu/<%= featured.id %>" class="btn-watch">
            <i class="bi bi-info-circle"></i> Voir Détails
          </a>
          <button class="btn-mylist" onclick="addToWatchLater(<%= featured.id %>)">
            <i class="bi bi-plus"></i> My List
          </button>
        </div>
      </div>
    </section>
  <% } %>

  <!-- ══ FILTRES ══ -->
  <section class="filters-section">
    <div class="filters-header">
      <h2 class="filters-title">
        <% if (type === 'ANIME') { %>
          <i class="bi bi-play-circle"></i> All Anime
        <% } else { %>
          <i class="bi bi-book"></i> All Manga
        <% } %>
        <span class="filters-count"><%= contenus.length %> titles</span>
      </h2>
    </div>

    <form class="filters-bar" method="GET" 
          action="<%= type === 'ANIME' ? '/contenu/anime' : '/contenu/manga' %>">

      <!-- Filtre Genre -->
      <div class="filter-group">
        <label><i class="bi bi-tag"></i> Genre</label>
        <select name="genre" onchange="this.form.submit()">
          <option value="">All Genres</option>
          <% genres.forEach(g => { %>
            <option value="<%= g.libelle %>" 
              <%= filters.genre === g.libelle ? 'selected' : '' %>>
              <%= g.libelle %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Filtre Saison (anime) / Chapitres (manga) -->
      <div class="filter-group">
        <% if (type === 'ANIME') { %>
          <label><i class="bi bi-collection-play"></i> Saisons</label>
          <select name="saisons" onchange="this.form.submit()">
            <option value="">All</option>
            <option value="1" <%= filters.saisons === '1' ? 'selected' : '' %>>1 saison</option>
            <option value="2" <%= filters.saisons === '2' ? 'selected' : '' %>>2 saisons</option>
            <option value="3" <%= filters.saisons === '3' ? 'selected' : '' %>>3+ saisons</option>
          </select>
        <% } else { %>
          <label><i class="bi bi-journals"></i> Chapitres</label>
          <select name="chapitres" onchange="this.form.submit()">
            <option value="">All</option>
            <option value="50"  <%= filters.chapitres === '50'  ? 'selected' : '' %>>- de 50</option>
            <option value="100" <%= filters.chapitres === '100' ? 'selected' : '' %>>50 - 100</option>
            <option value="101" <%= filters.chapitres === '101' ? 'selected' : '' %>>+ de 100</option>
          </select>
        <% } %>
      </div>

      <!-- Filtre Statut -->
      <div class="filter-group">
        <label><i class="bi bi-activity"></i> Statut</label>
        <select name="statut" onchange="this.form.submit()">
          <option value="">All</option>
          <option value="EN_COURS"  <%= filters.statut === 'EN_COURS'  ? 'selected' : '' %>>En cours</option>
          <option value="TERMINE"   <%= filters.statut === 'TERMINE'   ? 'selected' : '' %>>Terminé</option>
        </select>
      </div>

      <!-- Filtre Rating -->
      <div class="filter-group">
        <label><i class="bi bi-star"></i> Rating min</label>
        <select name="rating" onchange="this.form.submit()">
          <option value="">All</option>
          <option value="3" <%= filters.rating === '3' ? 'selected' : '' %>>3+ ⭐</option>
          <option value="4" <%= filters.rating === '4' ? 'selected' : '' %>>4+ ⭐</option>
          <option value="5" <%= filters.rating === '5' ? 'selected' : '' %>>5 ⭐</option>
        </select>
      </div>

      <!-- Reset -->
      <% if (filters.genre || filters.statut || filters.rating || filters.saisons || filters.chapitres) { %>
        <a href="<%= type === 'ANIME' ? '/contenu/anime' : '/contenu/manga' %>" 
           class="filter-reset">
          <i class="bi bi-x-circle"></i> Reset
        </a>
      <% } %>

    </form>
  </section>

  <!-- ══ GRILLE CONTENUS ══ -->
  <section class="catalogue-grid-section">
    <% if (contenus.length > 0) { %>
      <div class="catalogue-grid">
        <% contenus.forEach(item => { %>
          <a href="/contenu/<%= item.id %>" class="cat-card">
            <div class="cat-card-img">
              <img src="<%= item.image_url %>" alt="<%= item.titre %>"/>
              <div class="cat-card-overlay">
                <span class="cat-card-rating">
                  <i class="bi bi-star-fill"></i> <%= item.note %>
                </span>
                <% if (item.statut === 'EN_COURS') { %>
                  <span class="cat-card-status ongoing">En cours</span>
                <% } else { %>
                  <span class="cat-card-status done">Terminé</span>
                <% } %>
              </div>
            </div>
            <div class="cat-card-info">
              <h3 class="cat-card-title"><%= item.titre %></h3>
              <div class="cat-card-meta">
                <% if (type === 'ANIME') { %>
                  <span><%= item.nb_saisons %> saison(s)</span>
                <% } else { %>
                  <span><%= item.nb_chapitres %> ch.</span>
                <% } %>
                <span class="meta-dot"></span>
                <span><%= item.date_sortie %></span>
              </div>
              <div class="cat-card-genres">
                <% if (item.Genres && item.Genres.length > 0) { %>
                  <% item.Genres.slice(0,2).forEach(g => { %>
                    <span class="genre-tag"><%= g.libelle %></span>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-catalogue">
        <i class="bi bi-search"></i>
        <p>No results found for your filters.</p>
        <a href="<%= type === 'ANIME' ? '/contenu/anime' : '/contenu/manga' %>" 
           class="btn-explore-content">
          Clear Filters
        </a>
      </div>
    <% } %>
  </section>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
  <script>
    function addToWatchLater(id) {
      fetch('/profile/watchlater/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contenu_id: id })
      })
      .then(r => r.json())
      .then(d => {
        if (d.success) {
          const btn = document.querySelector('.btn-mylist');
          btn.innerHTML = '<i class="bi bi-check"></i> Added!';
        }
      });
    }
  </script>
</body>
</html>