<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ma Liste – OTACORE</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
</head>
<body class="landing-body">

  <%- include('partials/navbar') %>

  <section class="mylist-header">
    <h1 class="mylist-title"><i class="bi bi-list-check"></i> Ma Liste</h1>
    <p class="mylist-subtitle"><%= watchLater.length %> élément(s) dans votre liste</p>

    <!-- Status filters -->
    <div class="mylist-filters">
      <a href="/profile/mylist" class="mylist-filter-btn <%= filter === '' ? 'active' : '' %>">Tout</a>
      <a href="/profile/mylist?filter=PLANIFIE" class="mylist-filter-btn <%= filter === 'PLANIFIE' ? 'active' : '' %>">Planifié</a>
      <a href="/profile/mylist?filter=EN_COURS" class="mylist-filter-btn <%= filter === 'EN_COURS' ? 'active' : '' %>">En cours</a>
      <a href="/profile/mylist?filter=TERMINE" class="mylist-filter-btn <%= filter === 'TERMINE' ? 'active' : '' %>">Terminé</a>
    </div>
  </section>

  <section class="mylist-section">
    <% if (watchLater.length > 0) { %>
      <div class="mylist-grid">
        <% watchLater.forEach(item => { %>
          <div class="mylist-card">
            <a href="/contenu/<%= item.contenu_id %>" class="mylist-card-img">
              <img src="<%= item.image_url || '/images/default-cover.jpg' %>" alt="<%= item.titre %>"/>
              <span class="mylist-card-type"><%= item.type %></span>
            </a>

            <div class="mylist-card-info">
              <h3 class="mylist-card-title"><%= item.titre %></h3>

              <!-- Status dropdown -->
              <form action="/profile/watchlater/status" method="POST" style="margin-bottom:8px;">
                <input type="hidden" name="contenu_id" value="<%= item.contenu_id %>"/>
                <select name="statut" class="mylist-status-select" onchange="this.form.submit()">
                  <option value="PLANIFIE" <%= item.statutSuivi === 'PLANIFIE' ? 'selected' : '' %>>Planifié</option>
                  <option value="EN_COURS" <%= item.statutSuivi === 'EN_COURS' ? 'selected' : '' %>>En cours</option>
                  <option value="TERMINE" <%= item.statutSuivi === 'TERMINE' ? 'selected' : '' %>>Terminé</option>
                </select>
              </form>

              <!-- Reminder section -->
              <div class="reminder-section" style="margin-top:8px;">
                <label style="font-size:0.8rem; color:var(--muted);">Rappel :</label>
                <div style="display:flex; gap:6px;">
                  <input type="datetime-local"
                         id="reminder-<%= item.contenu_id %>"
                         value="<%= item.reminder_date ? new Date(item.reminder_date).toISOString().slice(0,16) : '' %>"
                         style="flex:1; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:6px; color:white; padding:4px 8px; font-size:0.8rem;"/>
                  <button onclick="setReminder(<%= item.contenu_id %>)" type="button"
                          style="background:#7c3aed; border:none; color:white; border-radius:6px; padding:4px 12px; font-size:0.8rem; cursor:pointer;">
                    <i class="bi bi-check-circle"></i> Enregistrer
                  </button>
                </div>
                <% if (item.reminder_date) { %>
                  <span class="badge bg-info" style="font-size:0.7rem; margin-top:4px;">
                    <i class="bi bi-alarm"></i> Rappel le <%= new Date(item.reminder_date).toLocaleString('fr-FR') %>
                    <% if (item.reminder_sent) { %> (envoyé) <% } %>
                  </span>
                <% } %>
              </div>
            </div>

            <!-- Remove button -->
            <form action="/profile/watchlater/remove" method="POST" style="position:absolute; top:8px; right:8px;">
              <input type="hidden" name="contenu_id" value="<%= item.contenu_id %>"/>
              <button type="submit" class="mylist-remove-btn" title="Supprimer">
                <i class="bi bi-x-lg"></i>
              </button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-mylist" style="text-align:center; padding:60px 20px; color:var(--muted);">
        <i class="bi bi-inbox" style="font-size:3rem; opacity:0.2;"></i>
        <p>Votre liste est vide.</p>
        <a href="/landing" class="btn btn-outline" style="margin-top:20px;">Explorer le catalogue</a>
      </div>
    <% } %>
  </section>

  <%- include('partials/footer') %>

  <script src="/js/script.js"></script>
  <script>
    function setReminder(contenuId) {
  const input = document.getElementById('reminder-' + contenuId);
  const value = input.value;
  if (!value) {
    alert('Veuillez choisir une date et une heure.');
    return;
  }

  fetch('/profile/watchlater/set-reminder', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      contenu_id: contenuId,
      reminder_date: new Date(value).toISOString()
    })
  })
  .then(r => r.json().then(data => ({ status: r.status, body: data })))
  .then(({ status, body }) => {
    if (status === 200 && body.success) {
      alert('Rappel sauvegardé !');
      location.reload();
    } else {
      alert('Erreur : ' + (body.message || 'Échec de la sauvegarde'));
    }
  })
  .catch(err => {
    console.error('Fetch error:', err);
    alert('Erreur réseau ou serveur indisponible.');
  });
}
  </script>
</body>
</html>