<nav class="navbar" id="mainNav">
  <a href="/landing" class="nav-brand">
    <div class="nav-logo-icon">
      <i class="bi bi-play-circle-fill"></i>
    </div>
    <span class="nav-brand-name">OTACORE</span>
  </a>

  <ul class="nav-links">
    <li><a href="/landing" class="<%= page === 'home' ? 'active' : '' %>">Home</a></li>
    <li><a href="/contenu/anime" class="<%= page === 'anime' ? 'active' : '' %>">Anime</a></li>
    <li><a href="/contenu/manga" class="<%= page === 'manga' ? 'active' : '' %>">Manga</a></li>
    <li><a href="/profile/mylist" class="<%= page === 'mylist' ? 'active' : '' %>">My List</a></li>
  </ul>

  <div class="nav-right">
    <form class="search-bar" action="/recherche" method="GET" style="display:flex; align-items:center; gap:8px;">
      <i class="fas fa-search" style="color:var(--muted);"></i>
      <input type="text" name="q" placeholder="Rechercher un anime ou manga..."
         style="background:none; border:none; color:white; outline:none; width:100%; font-size:0.9rem;"
         value=""/>
    </form>
    <a href="#" class="nav-icon-btn">
      <i class="bi bi-bell"></i>
    </a>
    <!-- Toujours afficher l'avatar car navbar = pages connectées uniquement -->
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/profile" class="avatar">
        <%= user.username.substring(0, 2).toUpperCase() %>
      </a>
    <% } %>
  </div>
</nav>

<div class="chat-widget">
  <button id="chatToggle" class="chat-toggle-button" type="button" aria-label="Open chat">
    <i class="bi bi-chat-dots-fill"></i>
  </button>

  <aside id="chatPanel" class="chat-panel" aria-hidden="true">
    <div class="chat-header">
      <div>
        <h3>OTACORE Chat</h3>
        <p>Ask a question and get an answer.</p>
      </div>
      <button id="chatClose" class="chat-close-btn" type="button" aria-label="Close chat">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <div id="chatMessages" class="chat-messages">
      <div class="chat-bubble assistant">Hi there ! i am the officiel otacore assistant powered by Local AI .</div>
    </div>

    <form id="chatForm" class="chat-form">
      <input id="chatInput" type="text" placeholder="Ask something..." autocomplete="off" />
      <button type="submit" aria-label="Send message"><i class="bi bi-send-fill"></i></button>
    </form>
  </aside>
</div>