<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>OTACORE - Stream the Multiverse</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="home-body">

  <!-- NAVBAR -->
  <nav class="home-nav">
    <a href="/" class="nav-brand">
      <div class="nav-logo-icon">
        <i class="bi bi-play-circle-fill"></i>
      </div>
      <span class="nav-brand-name">OTACORE</span>
    </a>
    <div class="home-nav-right">
      <a href="/auth/login" class="btn-login-nav">Log In</a>
      <a href="/auth/signup" class="btn-signup-nav">Sign Up</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="home-hero">
    <div class="home-hero-overlay"></div>
    <div class="home-hero-content">
      <div class="home-badge">
        <i class="bi bi-stars"></i> The Ultimate Anime & Manga Platform
      </div>
      <h1 class="home-title">
        Stream the<br/><span>Multiverse</span>
      </h1>
      <p class="home-subtitle">
        Discover thousands of anime and manga titles.<br/>
        Your next obsession is one click away.
      </p>
      <div class="home-actions">
        <a href="/auth/signup" class="btn-start">
          <i class="bi bi-play-fill"></i> Start Watching
        </a>
        <a href="/auth/login" class="btn-explore">
          Log In
        </a>
      </div>
      <!-- Stats -->
      <div class="home-stats">
        <div class="stat">
          <span class="stat-number">10K+</span>
          <span class="stat-label">Anime titles</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">5K+</span>
          <span class="stat-label">Manga titles</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">Free</span>
          <span class="stat-label">Forever</span>
        </div>
      </div>
    </div>
  </section>

</body>
</html>