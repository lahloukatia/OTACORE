<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= contenu.titre %> – OTACORE</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
</head>
<body class="landing-body">

  <%- include('partials/navbar') %>

  <!-- DETAILS HERO -->
  <section class="details-hero">
    <div class="details-hero-bg" style="background-image: url('<%= contenu.image_url || '/images/default-cover.jpg' %>')"></div>
    <div class="details-hero-overlay"></div>
    <div class="details-hero-content">
      <!-- Cover -->
      <div class="details-cover">
        <img src="<%= contenu.image_url || '/images/default-cover.jpg' %>" alt="<%= contenu.titre %>"/>
      </div>
      <!-- Main info -->
      <div class="details-main-info">
        <span class="details-type-badge">
          <% if (contenu.type === 'ANIME') { %>
            <i class="bi bi-play-circle-fill"></i> Anime
          <% } else { %>
            <i class="bi bi-book-fill"></i> Manga
          <% } %>
        </span>

        <h1 class="details-title"><%= contenu.titre %></h1>

        <!-- Star rating -->
        <div class="details-rating">
          <% for (let i = 1; i <= 5; i++) { %>
            <i class="bi bi-star<%= i <= Math.round(contenu.note) ? '-fill' : '' %> star<%= i <= Math.round(contenu.note) ? '-filled' : '-empty' %>"></i>
          <% } %>
          <span class="rating-value"><%= parseFloat(contenu.note).toFixed(1) %> / 5</span>
        </div>

        <!-- Meta row -->
        <div class="details-meta-row">
          <% if (contenu.type === 'ANIME') { %>
            <span class="details-meta-item">
              <i class="bi bi-collection-play"></i> <%= contenu.nb_saisons %> saison(s)
            </span>
            <% if (contenu.duree_episode) { %>
              <span class="details-meta-sep">|</span>
              <span class="details-meta-item">
                <i class="bi bi-clock"></i> <%= contenu.duree_episode %> min/ep
              </span>
            <% } %>
          <% } else { %>
            <span class="details-meta-item">
              <i class="bi bi-journals"></i> <%= contenu.nb_chapitres %> chapitres
            </span>
          <% } %>
          <span class="details-meta-sep">|</span>
          <span class="details-meta-item">
            <i class="bi bi-calendar"></i> <%= contenu.date_sortie %>
          </span>
          <span class="details-meta-sep">|</span>
          <span class="details-meta-item">
            <i class="bi bi-person"></i> <%= contenu.auteur || 'Inconnu' %>
          </span>
          <span class="details-meta-sep">|</span>
          <span class="details-meta-item" style="color: <%= contenu.statut === 'EN_COURS' ? '#22c55e' : '#c084fc' %>;">
            <i class="bi bi-activity"></i> <%= contenu.statut === 'EN_COURS' ? 'En cours' : 'Terminé' %>
          </span>
        </div>

        <!-- Synopsis -->
        <p class="details-synopsis"><%= contenu.synopsis || 'Aucun synopsis disponible.' %></p>

        <!-- Action buttons -->
        <div class="details-actions">
          <% if (contenu.trailer_url) { %>
            <a href="<%= contenu.trailer_url %>" target="_blank" class="btn-trailer">
              <i class="bi bi-play-fill"></i> Bande-annonce
            </a>
          <% } else { %>
            <button class="btn-trailer btn-disabled" disabled>
              <i class="bi bi-play-fill"></i> Bande-annonce
            </button>
          <% } %>
          <button class="btn-add-list" onclick="addToWatchLater(<%= contenu.id %>)">
            <i class="bi bi-plus"></i> Ajouter à ma liste
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAILS GRID -->
  <section class="details-grid-section">
    <div class="details-grid">
      <!-- Genres -->
      <div class="detail-card">
        <div class="detail-card-icon"><i class="bi bi-tags"></i></div>
        <div class="detail-card-content">
          <span class="detail-card-label">Genres</span>
          <div class="genres-list">
            <% if (contenu.Genres && contenu.Genres.length > 0) { %>
              <% contenu.Genres.forEach(genre => { %>
                <span class="genre-tag"><%= genre.libelle %></span>
              <% }) %>
            <% } else { %>
              <span class="genre-tag">Aucun genre</span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Classification -->
      <div class="detail-card">
        <div class="detail-card-icon"><i class="bi bi-exclamation-triangle"></i></div>
        <div class="detail-card-content">
          <span class="detail-card-label">Classification</span>
          <span class="detail-card-value"><%= contenu.classification || 'TOUT_PUBLIC' %></span>
          <span class="detail-card-age">Âge recommandé : <%= contenu.age_recommande || 0 %>+</span>
        </div>
      </div>

      <!-- Type & statut -->
      <div class="detail-card">
        <div class="detail-card-icon"><i class="bi bi-info-circle"></i></div>
        <div class="detail-card-content">
          <span class="detail-card-label">Type</span>
          <span class="detail-card-value"><%= contenu.type %></span>
          <span class="detail-card-label" style="margin-top:8px;">Statut</span>
          <span class="detail-card-value"><%= contenu.statut === 'EN_COURS' ? 'En cours' : 'Terminé' %></span>
        </div>
      </div>

      <!-- Author -->
      <div class="detail-card">
        <div class="detail-card-icon"><i class="bi bi-pencil"></i></div>
        <div class="detail-card-content">
          <span class="detail-card-label">Auteur</span>
          <span class="detail-card-value"><%= contenu.auteur || 'Inconnu' %></span>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="/js/script.js"></script>
  <script>
    function addToWatchLater(id) {
  fetch('/profile/watchlater/add', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ contenu_id: id })
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      const btn = document.querySelector('.btn-add-list');
      btn.innerHTML = '<i class="bi bi-check-lg"></i> Ajouté !';
      btn.classList.add('btn-added');
      // Update notification badge immediately
      if (typeof window.updateBadge === 'function') {
        window.updateBadge();
      }
    }
  });
}
  </script>
</body>
</html>