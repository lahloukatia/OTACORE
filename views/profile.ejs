<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Profil – OTACORE</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
</head>
<body class="landing-body">

  <%- include('partials/navbar') %>

  <!-- PROFILE HEADER -->
  <div class="profile-header" style="margin-top:60px;">
    <div class="profile-banner"></div>
    <div class="profile-info">
      <div class="profile-avatar">
        <%= user.username.substring(0, 2).toUpperCase() %>
      </div>
      <div class="profile-details">
        <h1 class="profile-username"><%= user.username %></h1>
        <p class="profile-bio"><%= user.bio || 'Aucune bio pour le moment.' %></p>
        <p style="color:var(--muted); font-size:0.85rem;">
          <i class="bi bi-calendar3"></i> Inscrit le <%= user.date_inscription ? new Date(user.date_inscription).toLocaleDateString('fr-FR') : 'inconnu' %>
          <% if (user.watchlistCount !== undefined) { %>
            &nbsp;|&nbsp; <i class="bi bi-collection-play"></i> <%= user.watchlistCount %> dans la liste
          <% } %>
        </p>
        <div class="profile-actions">
          <a href="/profile/edit" class="btn-edit-profile">
            <i class="bi bi-pencil"></i> Modifier le profil
          </a>
          <a href="/auth/logout" class="btn-logout">
            <i class="bi bi-box-arrow-right"></i> Déconnexion
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- RECENTLY VIEWED -->
  <section class="landing-section" style="margin-top:20px;">
    <div class="section-header">
      <h2 class="section-title">
        <i class="bi bi-clock-history"></i> Consultés récemment
      </h2>
    </div>
    <% if (recentlyViewed && recentlyViewed.length > 0) { %>
      <div class="cards-row">
        <% recentlyViewed.forEach(item => { %>
          <a href="/contenu/<%= item.id %>" class="recent-card">
            <img src="<%= item.image_url || '/images/default-cover.jpg' %>" alt="<%= item.titre %>"/>
            <div class="recent-card-name"><%= item.titre %></div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-section">
        <i class="bi bi-hourglass-split"></i>
        <p>Vous n'avez encore rien regardé.</p>
        <a href="/landing" class="btn-explore-content">Explorer le catalogue</a>
      </div>
    <% } %>
  </section>

  <!-- MY LIST LINK -->
  <section class="landing-section" style="background: none;">
    <div class="section-header">
      <h2 class="section-title">
        <i class="bi bi-list-check"></i> Ma Liste
      </h2>
    </div>
    <div class="empty-section" style="background:var(--card); border-radius:12px; padding:30px; border:1px solid var(--border);">
      <i class="bi bi-collection-play" style="font-size:2rem; color:var(--purple-soft);"></i>
      <p style="margin:10px 0; color:var(--text);">
        Organisez votre collection, fixez des rappels et suivez votre progression.
      </p>
      <a href="/profile/mylist" class="btn-explore-content">
        <i class="bi bi-arrow-right"></i> Accéder à ma liste
      </a>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="/js/script.js"></script>
</body>
</html>