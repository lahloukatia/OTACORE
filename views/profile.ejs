<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>OTACORE - Profile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="landing-body">

  <%- include('partials/navbar') %>

  <!-- ══ PROFILE HEADER ══ -->
  <section class="profile-header">
    <div class="profile-banner"></div>
    <div class="profile-info">
      <!-- Avatar dynamique -->
      <div class="profile-avatar">
        <%= user.username.substring(0, 2).toUpperCase() %>
      </div>
      <div class="profile-details">
        <!-- Username dynamique -->
        <h2 class="profile-username"><%= user.username %></h2>
        <p class="profile-bio"><%= user.bio || 'No bio yet.' %></p>
       <div class="profile-actions">
  <a href="/profile/edit" class="btn-edit-profile">
    <i class="bi bi-pencil"></i> Edit Profile
  </a>
  <a href="/auth/logout" class="btn-logout">
    <i class="bi bi-box-arrow-right"></i> Sign Out
  </a>
</div>
      </div>
    </div>
  </section>

  <!-- ══ WATCH LATER ══ -->
  <section class="landing-section">
    <div class="section-header">
      <h2 class="section-title">
        <i class="bi bi-clock"></i> Watch Later
      </h2>
      <!-- Watch Later view all -->
<a href="/profile/mylist" class="view-all">VIEW ALL</a>

<!-- Recently Viewed — pas de view all, juste scroll -->
    </div>
    <div class="cards-row">
      <% if (watchLater && watchLater.length > 0) { %>
        <% watchLater.forEach(item => { %>
          <a href="/contenu/<%= item.contenu_id %>" class="trend-card">
            <img src="<%= item.image_url %>" alt="<%= item.titre %>"/>
            <div class="trend-card-overlay">
              <div class="trend-card-name"><%= item.titre %></div>
              <div class="trend-card-status"><%= item.statutSuivi %></div>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <div class="empty-section">
          <i class="bi bi-clock"></i>
          <p>Your Watch Later list is empty.</p>
          <a href="/landing" class="btn-explore-content">Explore Content</a>
        </div>
      <% } %>
    </div>
  </section>

  <!-- ══ RECENTLY VIEWED ══ -->
  <section class="landing-section">
    <div class="section-header">
      <h2 class="section-title">
        <i class="bi bi-eye"></i> Recently Viewed
      </h2>
     <!-- Watch Later view all -->
<a href="/profile/mylist" class="view-all">VIEW ALL</a>

<!-- Recently Viewed — pas de view all, juste scroll -->
    </div>
    <div class="cards-row">
      <% if (recentlyViewed && recentlyViewed.length > 0) { %>
        <% recentlyViewed.forEach(item => { %>
          <a href="/contenu/<%= item.contenu_id %>" class="recent-card">
            <img src="<%= item.image_url %>" alt="<%= item.titre %>"/>
            <div class="recent-card-name"><%= item.titre %></div>
          </a>
        <% }) %>
      <% } else { %>
        <div class="empty-section">
          <i class="bi bi-eye"></i>
          <p>You haven't viewed any content yet.</p>
          <a href="/landing" class="btn-explore-content">Start Exploring</a>
        </div>
      <% } %>
    </div>
  </section>

  <!-- ══ FOOTER ══ -->
  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>