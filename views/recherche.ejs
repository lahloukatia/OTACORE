<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Recherche – OTACORE</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
</head>
<body class="landing-body">

  <%- include('partials/navbar') %>

  <section class="landing-section" style="margin-top:60px;">
    <div class="section-header">
      <h2 class="section-title">
        <i class="bi bi-search"></i> Résultats pour "<%= query %>"
      </h2>
      <span class="filters-count"><%= results.length %> résultat(s)</span>
    </div>

    <% if (results.length > 0) { %>
      <div class="catalogue-grid">
        <% results.forEach(item => { %>
          <a href="/contenu/<%= item.id %>" class="cat-card">
            <div class="cat-card-img">
              <img src="<%= item.image_url || '/images/default-cover.jpg' %>" alt="<%= item.titre %>"/>
              <div class="cat-card-overlay">
                <span class="cat-card-rating">
                  <i class="bi bi-star-fill"></i> <%= item.note %>
                </span>
              </div>
            </div>
            <div class="cat-card-info">
              <h3 class="cat-card-title"><%= item.titre %></h3>
              <div class="cat-card-meta">
                <span><%= item.type %></span>
                <span class="meta-dot"></span>
                <span><%= item.date_sortie %></span>
              </div>
              <div class="cat-card-genres">
                <% if (item.Genres) { %>
                  <% item.Genres.slice(0,3).forEach(g => { %>
                    <span class="genre-tag"><%= g.libelle %></span>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-catalogue" style="padding:60px 20px;">
        <i class="bi bi-search" style="font-size:3rem; opacity:0.2;"></i>
        <p>Aucun résultat pour "<%= query %>".</p>
        <a href="/landing" class="btn btn-outline" style="margin-top:20px;">
          <i class="bi bi-arrow-left"></i> Retour à l'accueil
        </a>
      </div>
    <% } %>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/script.js"></script>
</body>
</html>